# Server
PORT=3000
RECEIVE_REPLY_ENDPOINT=/receive-reply

# Webhook auth — if set, every inbound request must include this header:
#   x-webhook-secret: <value>
WEBHOOK_SECRET=

# MongoDB
MONGODB_URI=mongodb://localhost:27017/lunalend

# Test mode — set to true to log the reply body instead of calling Instantly
TEST_MODE=false

# Instantly API
# Base URL for the Instantly reply endpoint
INSTANTLY_API_BASE_URL=https://api.instantly.ai/api/v1

# Fallback API key used when tenant lookup fails or MongoDB is unavailable.
# Primary key is pulled from Tenant.credentials.instantlyApiKey in MongoDB.
INSTANTLY_API_KEY=
